#!/usr/bin/env node

const fs = require("node:fs");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

const root = path.resolve(__dirname, "..");
const slidesRoot = path.join(root, "slides");
const args = process.argv.slice(2);
const dryRunIndex = args.indexOf("--dry-run");
const dryRun = dryRunIndex !== -1;

if (dryRun) {
    args.splice(dryRunIndex, 1);
}

function usage() {
    console.log(
        "Usage: ./scripts/create-deck <course> <chapter> \"<title>\" [--dry-run]"
    );
    console.log("");
    console.log(
        "Example: ./scripts/create-deck cis215 ch02 "
        + "\"Data Collection and Preparation\""
    );
}

if (args.includes("--help") || args.includes("-h")) {
    usage();
    process.exit(0);
}

if (args.length !== 3 || args.some((arg) => arg.startsWith("--"))) {
    usage();
    process.exit(2);
}

const [courseSlug, chapterSlug, title] = args;
const slugPattern = /^[a-z][a-z0-9-]*$/;

if (!slugPattern.test(courseSlug) || !slugPattern.test(chapterSlug)) {
    console.error(
        "Course and chapter names must be lowercase slugs, such as cis215 and ch02."
    );
    process.exit(2);
}

if (!title.trim()) {
    console.error("The deck title cannot be empty.");
    process.exit(2);
}

const sharedStyle = path.join(slidesRoot, "shared", "deck.css");
const sharedScript = path.join(slidesRoot, "shared", "deck.js");
if (!fs.existsSync(sharedStyle) || !fs.existsSync(sharedScript)) {
    console.error("The shared deck runtime is missing. Run this script in the repo.");
    process.exit(1);
}

const coursePath = path.join(slidesRoot, courseSlug);
const chapterPath = path.join(coursePath, chapterSlug);
const deckPath = path.join(chapterPath, "index.html");
const readmePath = path.join(chapterPath, "README.md");
const previewsPath = path.join(chapterPath, "previews");
const courseIndexPath = path.join(coursePath, "index.html");
const courseIndexExisted = fs.existsSync(courseIndexPath);

if (fs.existsSync(chapterPath)) {
    console.error(`Refusing to replace existing directory: ${chapterPath}`);
    process.exit(1);
}

function escapeHtml(value) {
    return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
}

function displayCourse(slug) {
    return slug.replaceAll("-", " ").toUpperCase();
}

function displayChapter(slug) {
    const chapterMatch = slug.match(/^ch(?:apter-?)?0*(\d+)$/);
    return chapterMatch ? `Chapter ${Number(chapterMatch[1])}` : slug.toUpperCase();
}

const courseName = displayCourse(courseSlug);
const chapterName = displayChapter(chapterSlug);
const safeTitle = escapeHtml(title.trim());
const safeCourseName = escapeHtml(courseName);
const safeChapterName = escapeHtml(chapterName);
const fullTitle = `${safeCourseName}: ${safeTitle}`;

const deckHtml = `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="${safeCourseName} ${safeChapterName} classroom presentation: ${safeTitle}.">
  <meta name="theme-color" content="#002B5C">
  <title>${fullTitle}</title>
  <link rel="stylesheet" href="../../shared/deck.css">
</head>
<body data-deck-title="${fullTitle}" data-course="${courseSlug}" data-chapter="${chapterSlug}">
  <main class="deck" id="presentation" aria-live="polite">
    <section class="slide dark active" data-notes="Welcome students and connect the topic to the prior class.&#10;&#10;Time: 0-3 minutes.">
      <div class="brand">Phoenix College · ${safeCourseName}</div>
      <div class="content">
        <div class="eyebrow">${safeChapterName}</div>
        <div class="rule"></div>
        <h1>${safeTitle}</h1>
        <p class="lede">Replace this line with the question or problem that gives the class session its purpose.</p>
      </div>
    </section>

    <section class="slide" data-notes="Frame the session around what students will do.&#10;&#10;Time: 3-6 minutes.">
      <div class="brand">${safeCourseName} · ${safeChapterName}</div>
      <div class="content">
        <div class="eyebrow">Today’s target</div>
        <h2>By the end of class, you can explain and apply the central idea.</h2>
        <div class="three-up">
          <article class="panel">
            <div class="number">01</div>
            <h3>Recognize</h3>
            <p>Identify the main concept in a concrete example.</p>
          </article>
          <article class="panel">
            <div class="number">02</div>
            <h3>Explain</h3>
            <p>Connect the concept to a useful decision or task.</p>
          </article>
          <article class="panel">
            <div class="number">03</div>
            <h3>Apply</h3>
            <p>Use the concept in guided practice.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="slide gold" data-notes="Give students time to commit to an answer before revealing it.&#10;&#10;Time: 6-10 minutes.">
      <div class="brand">${safeCourseName} · Practice</div>
      <div class="content">
        <div class="eyebrow navy-text">Check your thinking</div>
        <h2>Add a question that reveals how students understand the topic.</h2>
        <div class="prompt">
          <p><strong>Discuss:</strong> What evidence would support your answer?</p>
        </div>
        <button class="reveal" type="button" aria-expanded="false">Reveal answer</button>
        <div class="answer">Replace this text with a concise model answer and reasoning.</div>
      </div>
    </section>

    <section class="slide dark" data-notes="Ask students to state one idea they can use after class.&#10;&#10;Time: 50-55 minutes.">
      <div class="brand">${safeCourseName} · Exit ticket</div>
      <div class="content">
        <div class="eyebrow">Close the loop</div>
        <h2>What can you explain now that you could not explain at the start?</h2>
        <div class="prompt">
          <p><strong>Exit ticket:</strong> Write one claim, one example, and one question you still have.</p>
        </div>
      </div>
    </section>
  </main>

  <div class="notes" id="notes" aria-live="polite" aria-label="Presenter notes">
    <h2>Presenter notes</h2>
    <p id="notes-content"></p>
  </div>
  <nav class="nav" aria-label="Presentation controls">
    <button type="button" id="previous" aria-label="Previous slide">←</button>
    <button type="button" id="toggle-notes" aria-label="Show presenter notes"
      aria-controls="notes" aria-pressed="false">N</button>
    <button type="button" id="next" aria-label="Next slide">→</button>
  </nav>

  <script src="../../shared/deck.js"></script>
</body>
</html>
`;

const chapterReadme = `# ${courseName} ${chapterName}: ${title.trim()}

Open \`index.html\` in a modern browser or use a local web server.

Replace the starter slides with the chapter content, then run:

\`\`\`bash
./scripts/validate-decks
\`\`\`

Add this chapter to \`slides/${courseSlug}/index.html\` before publication.
`;

const courseIndex = `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="${safeCourseName} classroom presentation collection.">
  <meta name="theme-color" content="#002B5C">
  <title>${safeCourseName} Presentations | Phoenix College</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' fill='%23002B5C'/%3E%3Cpath d='M14 48V30h8v18zm14 0V18h8v30zm14 0V8h8v40z' fill='%23F2B134'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="../shared/catalog.css">
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to chapters</a>
  <header class="site-header">
    <div class="site-header__inner">
      <p class="site-name">${safeCourseName} Presentations</p>
      <a href="../">All courses</a>
    </div>
  </header>
  <main id="main-content">
    <p class="eyebrow">Phoenix College</p>
    <h1>${safeCourseName} classroom presentations.</h1>
    <p class="intro">Choose a chapter to open its browser-based presentation.</p>
    <div class="cards">
      <a class="card" href="${chapterSlug}/">
        <div>
          <p class="eyebrow">${safeChapterName}</p>
          <h2>${safeTitle}</h2>
        </div>
        <span class="card__action">Open the presentation →</span>
      </a>
    </div>
  </main>
  <footer>Phoenix College ${safeCourseName} classroom presentations.</footer>
</body>
</html>
`;

const plannedFiles = [deckPath, readmePath, previewsPath];
if (!courseIndexExisted) {
    plannedFiles.push(courseIndexPath);
}

if (dryRun) {
    console.log("Dry run. No files were written.");
    for (const filePath of plannedFiles) {
        console.log(`Would create: ${path.relative(root, filePath)}`);
    }
    process.exit(0);
}

fs.mkdirSync(previewsPath, { recursive: true });
fs.writeFileSync(deckPath, deckHtml, { flag: "wx" });
fs.writeFileSync(readmePath, chapterReadme, { flag: "wx" });

if (!courseIndexExisted) {
    fs.writeFileSync(courseIndexPath, courseIndex, { flag: "wx" });
}

console.log(`Created: ${path.relative(root, chapterPath)}`);
if (courseIndexExisted) {
    console.log(`Remember to add ${chapterName} to slides/${courseSlug}/index.html.`);
} else {
    console.log(`Remember to add ${courseName} to slides/index.html.`);
}

const validation = spawnSync(path.join(__dirname, "validate-decks"), [], {
    cwd: root,
    stdio: "inherit",
});
process.exitCode = validation.status ?? 1;
